# ── BD & Prisma ──────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://test_user:test_password@localhost:5433/clubit_test?schema=public"
PRISMA_STUDIO=""
PRISMA_STUDIO_CROSS=""

# ── Security ──────────────────────────────────────────────────────────────
JWT_SECRET="test_secret_key_123"
INTERNAL_API_KEY="super-secret-test-key-123"
SALT_ROUNDS=12
FRONTEND_URLS="http://localhost:4200,http://127.0.0.1:4200"

# ── MercadoPago ──────────────────────────────────────────────────────────────
# Obtener en: https://www.mercadopago.cl/developers/panel/app → Credenciales de prueba
MERCADOPAGO_ACCESS_TOKEN=APP_USR-268755672129035-032117-84dbec438c9643b04b2b5035ce67ed8c-3284094994
# URLs a donde MP redirige al usuario tras completar el pago (frontend)
MERCADOPAGO_BACK_URL_SUCCESS=url-success
MERCADOPAGO_BACK_URL_FAILURE=url-failure
MERCADOPAGO_BACK_URL_PENDING=url-pending
# Secret para validar la firma de los webhooks (obténlo en la config de tu app en MP Developers)
# En desarrollo local puedes dejarlo vacío y se omitirá la validación
MERCADOPAGO_WEBHOOK_SECRET=

# ── Notifications ─────────────────────────────────────────────────────────────
RESEND_API_KEY=api-key-resend
MAIL_FROM="Clubit <no-reply@mail.clubit.cl>"

# ── Storage Logos with Cloudinary ─────────────────────────────────────────────────────────────
